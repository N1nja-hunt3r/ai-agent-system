# ============================================================================
# AI AGENT SYSTEM - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your API keys
# This system supports multiple LLM providers with intelligent fallback

# ============================================================================
# PRIMARY LLM CONFIGURATION
# ============================================================================

# Primary LLM Provider (deepseek, nemotron, glm, gemma, gpt-oss)
PRIMARY_LLM_PROVIDER=deepseek

# Fallback providers (comma-separated, in order of preference)
FALLBACK_LLM_PROVIDERS=nemotron,glm,gemma,gpt-oss

# ============================================================================
# DEEPSEEK MODELS (Reasoning + Coding Excellence)
# ============================================================================
# DeepSeek V4 Flash: 284B MoE, fast coding, 1M token context
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_FLASH_MODEL=deepseek-v4-flash
DEEPSEEK_PRO_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# DeepSeek Model Selection for different tasks
DEEPSEEK_REASONING_MODEL=deepseek-v4-pro
DEEPSEEK_CODING_MODEL=deepseek-v4-flash
DEEPSEEK_CHAT_MODEL=deepseek-v4-flash

# ============================================================================
# NEMOTRON MODELS (Omni-Modal: Text, Image, Video, Speech)
# ============================================================================
# Nemotron-3-Nano-Omni: Multimodal reasoning model
NEMOTRON_API_KEY=your_nemotron_api_key_here
NEMOTRON_OMNI_MODEL=nemotron-3-nano-omni-30b-a3b-reasoning
NEMOTRON_SAFETY_MODEL=nemotron-3-content-safety
NEMOTRON_BASE_URL=https://api.nvidia.com/v1/nemotron

# Nemotron Model Selection
NEMOTRON_MULTIMODAL_MODEL=nemotron-3-nano-omni-30b-a3b-reasoning
NEMOTRON_SAFETY_CHECK_MODEL=nemotron-3-content-safety

# ============================================================================
# GLM MODELS (Agentic Workflows + Reasoning)
# ============================================================================
# GLM-5.1: Flagship for agentic workflows, 1M token context
# GLM-4.7: Multilingual agentic coding partner
GLM_API_KEY=your_glm_api_key_here
GLM_5_1_MODEL=glm-5.1
GLM_4_7_MODEL=glm-4.7
GLM_BASE_URL=https://api.chatglm.cn/v1

# GLM Model Selection
GLM_REASONING_MODEL=glm-5.1
GLM_CODING_MODEL=glm-4.7
GLM_AGENTIC_MODEL=glm-5.1

# ============================================================================
# GEMMA MODELS (Reasoning + Fine-tuning)
# ============================================================================
# Gemma-4-31B: Dense 31B model for frontier reasoning
GEMMA_API_KEY=your_gemma_api_key_here
GEMMA_31B_MODEL=gemma-4-31b-it
GEMMA_BASE_URL=https://api.gemma.ai/v1

# Gemma Model Selection
GEMMA_REASONING_MODEL=gemma-4-31b-it
GEMMA_CODING_MODEL=gemma-4-31b-it

# ============================================================================
# GPT-OSS MODELS (Efficient MoE)
# ============================================================================
# GPT-OSS-20B: Smaller MoE for efficient reasoning
GPT_OSS_API_KEY=your_gpt_oss_api_key_here
GPT_OSS_20B_MODEL=gpt-oss-20b
GPT_OSS_BASE_URL=https://api.gpt-oss.com/v1

# GPT-OSS Model Selection
GPT_OSS_REASONING_MODEL=gpt-oss-20b
GPT_OSS_EFFICIENT_MODEL=gpt-oss-20b

# ============================================================================
# IMAGE GENERATION (FLUX.2)
# ============================================================================
# FLUX.2-Klein-4B: Fast image generation and editing
FLUX_API_KEY=your_flux_api_key_here
FLUX_IMAGE_MODEL=flux.2-klein-4b
FLUX_BASE_URL=https://api.flux.ai/v1

# ============================================================================
# SPEECH-TO-TEXT (STT) CONFIGURATION
# ============================================================================
STT_PROVIDER=whisper
WHISPER_MODEL=base
WHISPER_LANGUAGE=en

# ============================================================================
# TEXT-TO-SPEECH (TTS) CONFIGURATION
# ============================================================================
TTS_PROVIDER=gtts
TTS_LANGUAGE=en
TTS_SPEED=1.0

# ============================================================================
# AGENT CONFIGURATION
# ============================================================================

# Default agent personality (jarvis, friday, edith, karen, veronica, etc.)
DEFAULT_AGENT=friday

# Agent behavior settings
AGENT_MEMORY_SIZE=100
AGENT_CONTEXT_LENGTH=2000
AGENT_RESPONSE_TIMEOUT=30

# Multi-agent settings
ENABLE_MULTI_AGENT=true
MAX_CONCURRENT_AGENTS=3
AGENT_COLLABORATION_ENABLED=true

# ============================================================================
# SYSTEM CONFIGURATION
# ============================================================================

# Application settings
APP_NAME=AI Agent System
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# Data storage
DATA_DIR=./data
LOGS_DIR=./logs
MODELS_DIR=./models

# Voice settings
VOICE_ENABLED=true
MICROPHONE_DEVICE=default
SPEAKER_DEVICE=default
VOICE_TIMEOUT=30

# Chat settings
CHAT_HISTORY_SIZE=50
CHAT_CONTEXT_LENGTH=4000
CHAT_MAX_TOKENS=2000

# ============================================================================
# API SERVER CONFIGURATION
# ============================================================================

# FastAPI settings
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false

# WebSocket settings
WEBSOCKET_ENABLED=true
WEBSOCKET_HEARTBEAT=30

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# SQLite (default)
DATABASE_URL=sqlite:///./data/agent.db

# Redis (for caching and messaging)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

# API authentication
API_KEY_ENABLED=false
API_KEY=your_api_key_here

# CORS settings
CORS_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=true

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ============================================================================
# FILE OPERATIONS CONFIGURATION
# ============================================================================

# File operations
FILE_OPERATIONS_ENABLED=true
FILE_BASE_PATH=./data/files
MAX_FILE_SIZE_MB=100

# ============================================================================
# MONITORING & LOGGING
# ============================================================================

# Application monitoring
METRICS_ENABLED=false
METRICS_PORT=9090

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable/disable features
FEATURE_VOICE=true
FEATURE_CHAT=true
FEATURE_FILE_OPS=true
FEATURE_DEVICE_ACCESS=false
FEATURE_LEARNING=true
FEATURE_MULTIMODAL=true
FEATURE_IMAGE_GEN=false

# ============================================================================
# ADVANCED SETTINGS
# ============================================================================

# Model optimization
USE_QUANTIZATION=false
USE_FLASH_ATTENTION=true
BATCH_SIZE=1

# Context window settings
MAX_CONTEXT_TOKENS=128000
MAX_OUTPUT_TOKENS=4096

# Reasoning settings
ENABLE_REASONING=true
REASONING_TIMEOUT=60
REASONING_COST_LIMIT=5.0
